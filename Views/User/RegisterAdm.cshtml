@using Library.Dto

@model UserDto


@{
    
    ViewData["title"] = "Cadastrar Administrador";
    
    int? role = ViewBag.UserRole as int?;

}


@section Styles {

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <meta charset="utf-8" />

}


<div class="conteiner bg-white">


    @await Html.PartialAsync("_MessageErrorPartial")


    <form id="adm-form" method="post" enctype="multipart/form-data" asp-controller="User" asp-action="RegisterAdm">


        @Html.AntiForgeryToken()


        <div class="d-flex justify-content-between alignalign-items-center mb-5">

            <h3>Cadastrar Administrador</h3>

            <div>

                <button id="save-button" type="submit" class="btn btn-success left" style="width:200px;margin-right:10px">Salvar</button>

                <a id="cancel-button" class="btn btn-primary left" style="width:200px" asp-controller="Login" asp-action="Login">Cancelar</a>

            </div>

        </div>
        

        <div class="mb-5"></div>


        @{
            await Html.RenderPartialAsync("~/Views/User/_UserPartial.cshtml", Model);
        }


        <div id="spinner" class="spinner" style="display: none;"></div>


        @Html.Hidden("Role", role)


    </form>


</div>


@section Scripts {
    
    <script src="~/js/register-adm.js" asp-append-version="true"></script>

}