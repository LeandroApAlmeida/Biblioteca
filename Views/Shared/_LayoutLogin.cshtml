<!DOCTYPE html>

<html lang="pt-br">

    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"]</title>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/Library.styles.css" asp-append-version="true" />
        <link rel="icon" type="image/png" sizes="16x16" href="~/img/house_icon_24.png" />
    </head>

    <body>

        <header id="main-menu">
            <h5 class="dynamic-text-shadow m-3" style="text-align: center;">BIBLIOTECA - SISTEMA PARA GESTÃO DO ACERVO PESSOAL</h5>
            <hr />
        </header>

        <div id="content-area" class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer id="page-footer" class="border-top footer text-muted">
            <div class="container">
                &copy; 2025 - Biblioteca
            </div>
        </footer>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/js/datatables.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>

        @await RenderSectionAsync("Scripts", required: false)

    </div>

    </body>

</html>