@model PersonModel

@using Library.Utils;

@{
    ViewData["title"] = "Editar Pessoa";
}

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta charset="utf-8" />
</head>

<body>

    <div class="conteiner">

        @if (TempData[Constants.error_message] != null) {
            <div class="alert alert-danger text-black" role="alert">
                @TempData[Constants.error_message]
            </div>
        }

        <div class="mb-1">
            <h3 class="text-black">Editar Pessoa</h3>
        </div>

        <div class="mb-5"></div>

        <form method="post" enctype="multipart/form-data" asp-controller="Person" asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label for="name" class="form-label">Nome</label>
                <input type="text" class="form-control" asp-for="Name" id="name" placeholder="Nome da pessoa">
                <span class="text-danger" asp-validation-for="Name"></span>
            </div>

            <div class="row g-3" display="flex">

                <div class="mb-3 col-sm-2" style="width: 60%;">
                    <label for="street" class="form-label">Rua</label>
                    <input type="text" class="form-control" asp-for="Street" id="street" placeholder="Nome da rua">
                    <span class="text-danger" asp-validation-for="Street"></span>
                </div>

                <div class="mb-3 col-sm-2" style="width: 20%;">
                    <label for="number" class="form-label">Número</label>
                    <input type="text" class="form-control" asp-for="Number" id="number" placeholder="Número do imóvel">
                    <span class="text-danger" asp-validation-for="Number"></span>
                </div>

                <div class="mb-3 col-sm-2" style="width: 20%;">
                    <label for="complement" class="form-label">Complemento</label>
                    <input type="text" class="form-control" asp-for="Complement" id="complement" placeholder="Complemento do imóvel">
                    <span class="text-danger" asp-validation-for="Complement"></span>
                </div>

            </div>

            <div class="row g-3" display="flex">

                <div class="mb-3" style="width: 80%;">
                    <label for="district" class="form-label">Bairro</label>
                    <input type="text" class="form-control" asp-for="District" id="district" placeholder="Bairro do endereço">
                    <span class="text-danger" asp-validation-for="District"></span>
                </div>

                <div class="mb-3 col-sm-2" style="width: 20%;">
                    <label for="postal-code" class="form-label">CEP</label>
                    <input type="text" class="form-control" asp-for="PostalCode" id="postal-code" placeholder="Código postal">
                    <span class="text-danger" asp-validation-for="PostalCode"></span>
                </div>

            </div>

            <div class="row g-3" display="flex">

                <div class="mb-3 col-sm-2" style="width: 60%;">
                    <label for="city" class="form-label">Município</label>
                    <input type="text" class="form-control" asp-for="City" id="city" placeholder="Nome do município">
                    <span class="text-danger" asp-validation-for="City"></span>
                </div>

                <div class="mb-3 col-sm-2" style="width: 20%;">
                    <label for="federal-state" class="form-label">Estado</label>
                    <input type="text" class="form-control" asp-for="FederalState" id="federal-state" placeholder="Nome do estado">
                    <span class="text-danger" asp-validation-for="FederalState"></span>
                </div>

                <div class="mb-3 col-sm-2" style="width: 20%;">
                    <label for="cowntry" class="form-label">País</label>
                    <input type="text" class="form-control" asp-for="Country" id="cowntry" placeholder="Nome do país">
                    <span class="text-danger" asp-validation-for="Country"></span>
                </div>

            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Informações complementares</label>
                <textarea id="description" class="form-control" style="resize:none" asp-for="Description" rows="10" cols="50" placeholder="Outros..."></textarea>
            </div>

            <div class="left gap-2 mt-4">
                <button type="submit" class="btn btn-success left" style="width:200px;margin-right:10px">Salvar</button>
                <a class="btn btn-primary left" style="width:200px" asp-controller="Person" asp-action="Manage">Cancelar</a>
            </div>

        </form>

    </div>

</body>