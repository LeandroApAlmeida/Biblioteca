@model PersonModel


@{

    ViewData["title"] = "Editar Pessoa";
    
}


@section Styles {

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta charset="utf-8" />

}


<div class="conteiner">


    @await Html.PartialAsync("_MessageErrorPartial")


    <form method="post" enctype="multipart/form-data" asp-controller="Person" asp-action="Edit">


        @Html.AntiForgeryToken()


        <div class="d-flex justify-content-between alignalign-items-center mb-5">

            <h3>Editar Pessoa</h3>

            <div>

                <button type="submit" class="btn btn-success left" style="width:200px;margin-right:10px">Salvar</button>

                <a class="btn btn-primary left" style="width:200px" asp-controller="Person" asp-action="Manage">Cancelar</a>

            </div>

        </div>


        <div class="mb-5"></div>


        <input type="hidden" asp-for="Id" />

        @{
            await Html.RenderPartialAsync("~/Views/Person/_PersonPartial.cshtml", Model);
        }


    </form>


</div>