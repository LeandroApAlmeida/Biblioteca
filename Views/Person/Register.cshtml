@model PersonModel


@{
    ViewData["title"] = "Cadastrar Pessoa";
}


@section Styles {

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta charset="utf-8" />

}


<div class="conteiner bg-white">

    
    @await Html.PartialAsync("_MessageErrorPartial")


    <form method="post" enctype="multipart/form-data" asp-controller="Person" asp-action="Register">


        @Html.AntiForgeryToken()


        <div class="d-flex justify-content-between alignalign-items-center mb-5">

            <h3>Cadastrar Pessoa</h3>

            <div>

                <button type="submit" class="btn btn-success left" style="width:200px;margin-right:10px">Salvar</button>

                <a class="btn btn-primary left" style="width:200px" asp-controller="Person" asp-action="Manage">Cancelar</a>

            </div>

        </div>


        <div class="mb-5"></div>


        @{
            await Html.RenderPartialAsync("~/Views/Person/_PersonPartial.cshtml", Model);
        }


    </form>


</div>


@section Scripts {

    <script type="module" src="~/js/register-person.js" asp-append-version="true"></script>

}